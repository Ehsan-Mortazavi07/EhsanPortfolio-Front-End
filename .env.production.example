# Set these in Vercel → Project → Settings → Environment Variables (Production)

# Public API URL — browser + client-side requests
NEXT_PUBLIC_API_URL=https://YOUR-BACKEND.onrender.com/v1

# Server-side fetches from Vercel (SSR) — same as public URL unless you use a private network
INTERNAL_API_URL=https://YOUR-BACKEND.onrender.com/v1

# Base URL for uploaded images (no /v1 suffix)
NEXT_PUBLIC_IMAGE_BASE_URL=https://YOUR-BACKEND.onrender.com

# Your Vercel frontend URL (used for SEO metadata)
NEXT_PUBLIC_SITE_URL=https://YOUR-FRONTEND.vercel.app
