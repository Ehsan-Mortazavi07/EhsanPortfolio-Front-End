{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm build",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.ehsanmor.ir" }],
      "destination": "https://ehsanmor.ir/:path*",
      "permanent": true
    }
  ]
}
